{
  "Anthropic": {
    "ApiKey": "DO-NOT-PUT-REAL-KEY-HERE — use Anthropic__ApiKey environment variable"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "NodeHealth": {
    "HeartbeatIntervalSeconds": 30,
    "SweepIntervalSeconds": 15
  },
  "ClaudeThrottle": {
    "MaxConcurrent": 3,
    "MaxWaitMs": 30000,
    "NodeParallelism": 3
  },
  "AspireDashboard": {
    "Frontend": {
      "EndpointUrls": "https://localhost:18888",
      "AuthMode": "BrowserToken"
    },
    "Otlp": {
      "EndpointUrl": "http://localhost:4317",
      "AuthMode": "ApiKey"
    },
    "Mcp": {
      "AuthMode": "ApiKey"
    },
    "Runner": {
      "LaunchBrowser": true,
      "PipeOutput": true,
      "SingleInstanceHandling": "ReplaceExisting",
      "AutoUpdate": true,
      "RestartOnFailure": true
    }
  }
}